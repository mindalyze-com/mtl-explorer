# Direct to backend (causes CORS issues)
# VITE_BACKEND_URL=http://localhost:8080/mtl/

# with Vite proxy (no CORS issues)
VITE_BACKEND_URL=./

# Dev-only: where the Vite proxy forwards /mtl/api requests.
# Defaults to http://localhost:8080 when unset (see vite.config.ts).
# Examples:
#   VITE_DEV_PROXY_TARGET=http://localhost:8080
#   VITE_DEV_PROXY_TARGET=http://192.168.2.77:8080
VITE_DEV_PROXY_TARGET=http://localhost:8080

