    "bootstrap-icons": "^1.13.1",
    "colormap": "2.3.2",
    "d3-geo": "^3.1.1",
    "d3-selection": "^3.0.0",
    "date-fns": "^4.3.0",
    "dexie": "^4.4.2",
    "highcharts": "^12.5.0",
    "highcharts-vue": "^2.0.1",
    "highlight.js": "^11.11.1",
    "lodash": "^4.17.23",
    "maplibre-gl": "^5.24.0",
    "p-limit": "^7.3.0",
