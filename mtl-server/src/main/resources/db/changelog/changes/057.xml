<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.10.xsd">

    <changeSet id="20260524_5_filter_ui_metadata_v2" author="codex">
        <comment>
            Move built-in filter UI metadata to the forward-only v2 shape.
            Metadata is local to each filter; inherited effective metadata is
            resolved by the server from SQL template includes.
        </comment>

        <update tableName="filter_config">
            <column name="ui_metadata">
                <![CDATA[
                {
                  "metadataVersion": 2,
                  "paramGroups": {
                    "scope": { "label": "Scope", "order": 10, "defaultOpen": "whenActive" },
                    "area": { "label": "Area", "order": 15, "defaultOpen": "whenActive" },
                    "tracks": { "label": "Tracks", "order": 20, "defaultOpen": "whenActive" }
                  },
                  "params": {
                    "DATE_TIME_FROM": {
                      "label": "From",
                      "group": "scope",
                      "widget": "dateTime",
                      "optional": true
                    },
                    "DATE_TIME_TO": {
                      "label": "To",
                      "group": "scope",
                      "widget": "dateTime",
                      "optional": true
                    },
                    "GEO_CIRCLE_1": {
                      "label": "Circle",
                      "group": "area",
                      "widget": "geoCircle",
                      "optional": true
                    },
                    "GEO_RECTANGLE_1": {
                      "label": "Rectangle",
                      "group": "area",
                      "widget": "geoRectangle",
                      "optional": true
                    },
                    "GEO_POLYGON_1": {
                      "label": "Polygon",
                      "group": "area",
                      "widget": "geoPolygon",
                      "optional": true
                    },
                    "TRACK_IDS": {
                      "label": "Selected tracks",
                      "group": "tracks",
                      "widget": "trackPicker",
                      "optional": true,
                      "optionsSource": {
                        "type": "originFilterResult"
                      }
                    }
                  }
                }
                ]]>
            </column>
            <where>filter_domain = 'GPS_TRACK' AND filter_name = 'SmartBaseFilter'</where>
        </update>

        <update tableName="filter_config">
            <column name="ui_metadata">
                <![CDATA[
                {
                  "metadataVersion": 2,
                  "paramGroups": {
                    "filter": { "label": "Year", "order": 30, "defaultOpen": true }
                  },
                  "params": {
                    "YEAR_FROM": {
                      "label": "From year",
                      "group": "filter",
                      "widget": "number",
                      "optional": false
                    },
                    "YEAR_TO": {
                      "label": "To year",
                      "group": "filter",
                      "widget": "number",
                      "optional": false
                    }
                  }
                }
                ]]>
            </column>
            <where>filter_domain = 'GPS_TRACK' AND filter_name = 'TracksByYear'</where>
        </update>

