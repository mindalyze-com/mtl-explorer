                  "params": {
                    "AVG_SPEED_MIN_KMH": {
                      "label": "Minimum average speed",
                      "group": "filter",
                      "widget": "number",
                      "optional": true,
                      "unit": "km/h"
                    },
                    "AVG_SPEED_MAX_KMH": {
                      "label": "Maximum average speed",
                      "group": "filter",
                      "widget": "number",
                      "optional": true,
                      "unit": "km/h"
                    }
                  },
                  "result": {
                    "gradient": {
                      "bucketCount": 100,
                      "metricLabel": "Average speed",
                      "metricUnit": "km/h",
                      "bucketLabel": "percentile",
                      "direction": "low-to-high"
                    }
                  }
                }
                ]]>
            </column>
            <where>filter_domain = 'GPS_TRACK' AND filter_name = 'TracksByAverageSpeedGradient'</where>
        </update>

