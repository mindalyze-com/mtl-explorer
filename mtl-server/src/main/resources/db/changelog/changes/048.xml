    <changeSet id="20260519_2_filter_display_order_ranges" author="patrick.heusser">
        <comment>
            Give built-in filter groups wide display-order ranges. The client
            orders filter selector groups by the lowest display_order inside
            each group, so these ranges define the preferred group order while
            leaving space for future filters.
        </comment>

        <!-- Core: 1000-1999 -->
        <update tableName="filter_config">
            <column name="display_order" valueNumeric="1000"/>
            <where>filter_domain = 'GPS_TRACK' AND filter_name = 'SmartBaseFilter'</where>
        </update>

        <!-- Activity: 2000-2999 -->
        <update tableName="filter_config">
            <column name="display_order" valueNumeric="2000"/>
            <column name="display_name" value="Activities by type"/>
            <where>filter_domain = 'GPS_TRACK' AND filter_name = 'ActivitiesByMainTypes'</where>
        </update>
        <update tableName="filter_config">
            <column name="display_order" valueNumeric="2010"/>
            <where>filter_domain = 'GPS_TRACK' AND filter_name = 'ActivitiesByKeyword'</where>
        </update>
        <update tableName="filter_config">
            <column name="display_order" valueNumeric="2020"/>
            <where>filter_domain = 'GPS_TRACK' AND filter_name = 'NonMotorizedTracks'</where>
        </update>
        <update tableName="filter_config">
            <column name="display_order" valueNumeric="2030"/>
            <where>filter_domain = 'GPS_TRACK' AND filter_name = 'MotorizedTracks'</where>
        </update>

        <!-- Date & Time: 3000-3999 -->
        <update tableName="filter_config">
            <column name="display_order" valueNumeric="3000"/>
            <where>filter_domain = 'GPS_TRACK' AND filter_name = 'TracksByYear'</where>
        </update>
        <update tableName="filter_config">
            <column name="display_order" valueNumeric="3010"/>
            <where>filter_domain = 'GPS_TRACK' AND filter_name = 'TracksByDay'</where>
        </update>
        <update tableName="filter_config">
            <column name="display_order" valueNumeric="3020"/>
            <where>filter_domain = 'GPS_TRACK' AND filter_name = 'TracksByQuarter'</where>
        </update>
        <update tableName="filter_config">
            <column name="display_order" valueNumeric="3030"/>
            <where>filter_domain = 'GPS_TRACK' AND filter_name = 'TracksByDayOfWeek'</where>
        </update>
        <update tableName="filter_config">
            <column name="display_order" valueNumeric="3040"/>
            <where>filter_domain = 'GPS_TRACK' AND filter_name = 'TracksByTimeOfDay'</where>
        </update>

        <!-- People: 4000-4999 -->
        <update tableName="filter_config">
            <column name="display_order" valueNumeric="4000"/>
            <where>filter_domain = 'GPS_TRACK' AND filter_name = 'ActivitiesWithSilja'</where>
        </update>
        <update tableName="filter_config">
            <column name="display_order" valueNumeric="4010"/>
            <where>filter_domain = 'GPS_TRACK' AND filter_name = 'ActivitiesWithOthers'</where>
        </update>

        <!-- Performance: 5000-5999 -->
        <update tableName="filter_config">
            <column name="display_order" valueNumeric="5000"/>
            <where>filter_domain = 'GPS_TRACK' AND filter_name = 'TracksByAverageSpeedGradient'</where>
        </update>
        <update tableName="filter_config">
            <column name="display_order" valueNumeric="5010"/>
            <where>filter_domain = 'GPS_TRACK' AND filter_name = 'TracksByDistanceGradient'</where>
        </update>
        <update tableName="filter_config">
            <column name="display_order" valueNumeric="5020"/>
            <where>filter_domain = 'GPS_TRACK' AND filter_name = 'TracksByElevationGainGradient'</where>
        </update>
        <update tableName="filter_config">
            <column name="display_order" valueNumeric="5030"/>
            <where>filter_domain = 'GPS_TRACK' AND filter_name = 'TracksByEnergyGradient'</where>
        </update>

        <!-- Quality: 6000-6999 -->
        <update tableName="filter_config">
            <column name="display_order" valueNumeric="6000"/>
            <where>filter_domain = 'GPS_TRACK' AND filter_name = 'SuspiciousTracks'</where>
        </update>
        <update tableName="filter_config">
