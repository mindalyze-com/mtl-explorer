<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.10.xsd">

    <!-- Enforce NOT NULL on point_long_lat: remove any existing rows with null geometry
         then add a NOT NULL constraint so future imports cannot store coordinate-less points. -->
    <changeSet id="20260403_1_point_long_lat_not_null" author="patrick.heusser">
        <sql>
            DELETE FROM gps_track_data_points WHERE point_long_lat IS NULL;
        </sql>
        <sql>
            ALTER TABLE gps_track_data_points ALTER COLUMN point_long_lat SET NOT NULL;
        </sql>
        <rollback>
            <sql>ALTER TABLE gps_track_data_points ALTER COLUMN point_long_lat DROP NOT NULL;</sql>
        </rollback>
    </changeSet>

</databaseChangeLog>
