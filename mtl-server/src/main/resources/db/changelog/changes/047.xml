    <changeSet id="20260518_5_scale_gradient_filter_buckets" author="patrick.heusser">
        <update tableName="filter_config">
            <column name="expression">
                <![CDATA[
                with base_tracks as (
                    select
                        gt.id,
                        (gt.track_length_in_meter / nullif(gt.track_duration_in_motion_secs, 0) * 3.6) as metric_value
                    from
                        gps_track gt
                    where
                        id = any (
                            select id
                            from ( [[~{/GPS_TRACK/SmartBaseFilter}]] ) base_filter
                        )
                        and gt.track_length_in_meter is not null
                        and gt.track_duration_in_motion_secs is not null
                        and gt.track_duration_in_motion_secs > 0
                ),
                filtered_tracks as (
                    select
                        id,
                        metric_value
                    from
                        base_tracks
                    where
                        (:AVG_SPEED_MIN_KMH is null or :AVG_SPEED_MIN_KMH = '' or metric_value >= cast(nullif(:AVG_SPEED_MIN_KMH, '') as double precision))
                        and (:AVG_SPEED_MAX_KMH is null or :AVG_SPEED_MAX_KMH = '' or metric_value <= cast(nullif(:AVG_SPEED_MAX_KMH, '') as double precision))
                ),
                ranked_tracks as (
                    select
                        id,
                        metric_value,
                        row_number() over (order by metric_value, id) as metric_rank,
                        count(*) over () as metric_count
                    from
                        filtered_tracks
                ),
                bucketed_tracks as (
                    select
                        id,
                        metric_value,
                        case
                            when metric_count <= 1 then 0
                            else round(((metric_rank - 1)::numeric * 99) / (metric_count - 1))::integer
                        end as bucket
                    from
                        ranked_tracks
                )
                select
                    id,
                    bucket::text as grp
                from
                    bucketed_tracks
                order by
                    bucket,
                    metric_value,
                    id
                ]]>
            </column>
            <where>filter_domain = 'GPS_TRACK' AND filter_name = 'TracksByAverageSpeedGradient'</where>
        </update>

