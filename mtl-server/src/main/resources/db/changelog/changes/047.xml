    <changeSet id="20260518_3_filter_ui_metadata_columns" author="patrick.heusser">
        <addColumn tableName="filter_config">
            <column name="filter_group" type="varchar(80)"/>
            <column name="group_semantics" type="varchar(50)"/>
            <column name="coloring_strategy" type="varchar(50)"/>
            <column name="legend_sort_strategy" type="varchar(50)"/>
            <column name="preferred_palette" type="varchar(80)"/>
            <column name="group_label_template" type="varchar(200)"/>
            <column name="ui_metadata" type="text"/>
        </addColumn>

        <addColumn tableName="filter_config_audit">
            <column name="filter_group" type="varchar(80)"/>
            <column name="group_semantics" type="varchar(50)"/>
            <column name="coloring_strategy" type="varchar(50)"/>
            <column name="legend_sort_strategy" type="varchar(50)"/>
            <column name="preferred_palette" type="varchar(80)"/>
            <column name="group_label_template" type="varchar(200)"/>
            <column name="ui_metadata" type="text"/>
        </addColumn>

        <createProcedure>
            <![CDATA[
            CREATE OR REPLACE FUNCTION filter_config_trigger()
            RETURNS TRIGGER AS $$
            BEGIN
                IF (TG_OP = 'UPDATE' OR TG_OP = 'DELETE') THEN
                    INSERT INTO filter_config_audit (
                        version, operation, changed_at,
                        id, filter_domain, filter_name, expression, filter_type, filter_category,
                        description, display_name, display_order,
                        filter_group, group_semantics, coloring_strategy, legend_sort_strategy,
                        preferred_palette, group_label_template, ui_metadata,
                        create_date, update_date
                    )
                    SELECT (SELECT COALESCE(MAX(version), 0) + 1 FROM filter_config_audit WHERE id = OLD.id),
                           TG_OP,
                           CURRENT_TIMESTAMP,
                           OLD.id,
                           OLD.filter_domain,
                           OLD.filter_name,
                           OLD.expression,
                           OLD.filter_type,
                           OLD.filter_category,
                           OLD.description,
                           OLD.display_name,
                           OLD.display_order::BIGINT,
                           OLD.filter_group,
                           OLD.group_semantics,
                           OLD.coloring_strategy,
                           OLD.legend_sort_strategy,
                           OLD.preferred_palette,
                           OLD.group_label_template,
                           OLD.ui_metadata,
                           OLD.create_date,
                           OLD.update_date;
                ELSIF (TG_OP = 'INSERT') THEN
                    INSERT INTO filter_config_audit (
                        version, operation, changed_at,
                        id, filter_domain, filter_name, expression, filter_type, filter_category,
                        description, display_name, display_order,
                        filter_group, group_semantics, coloring_strategy, legend_sort_strategy,
                        preferred_palette, group_label_template, ui_metadata,
                        create_date, update_date
                    )
                    SELECT 1,
                           TG_OP,
                           CURRENT_TIMESTAMP,
                           NEW.id,
                           NEW.filter_domain,
                           NEW.filter_name,
                           NEW.expression,
                           NEW.filter_type,
                           NEW.filter_category,
                           NEW.description,
                           NEW.display_name,
                           NEW.display_order::BIGINT,
                           NEW.filter_group,
                           NEW.group_semantics,
                           NEW.coloring_strategy,
                           NEW.legend_sort_strategy,
                           NEW.preferred_palette,
                           NEW.group_label_template,
                           NEW.ui_metadata,
                           NEW.create_date,
                           NEW.update_date;
                END IF;
                RETURN NEW;
            END;
            $$
            LANGUAGE plpgsql;
            ]]>
        </createProcedure>
    </changeSet>

